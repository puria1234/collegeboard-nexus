{
  "manifest_version": 3,
  "name": "CollegeBoard Nexus",
  "version": "1.0.1",
  "description": "Extract and export questions from AP Classroom, and hide answers while studying",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://integrate.api.nvidia.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://apclassroom.collegeboard.org/*",
        "*://*.learnosity.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://apclassroom.collegeboard.org/*",
        "*://*.learnosity.com/*"
      ],
      "js": [
        "hider.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
